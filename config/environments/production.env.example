# =============================================================================
# Modèle production (serveur + nginx + PM2) — sans valeurs réelles à copier telles quelles
# =============================================================================
# Sur la VM, à la racine du dépôt :
#   cp config/environments/production.env.example .env.production
#
# Next.js charge `.env.production` avec `pnpm start` / `next start`.
# `ecosystem.config.cjs` charge `.env.production` puis `.env` avant de démarrer l’app.
# =============================================================================

NODE_ENV=production

# Port d’écoute local derrière nginx (entier positif). Si absent, voir défaut dans `ecosystem.config.cjs`.
# PORT=
# HOSTNAME=

# URL publique du site, sans slash final
NEXT_PUBLIC_APP_URL=""

# Matomo — instance self‑hosted ; laisser vides pour désactiver
NEXT_PUBLIC_MATOMO_URL=""
NEXT_PUBLIC_MATOMO_SITE_ID=""

# PostgreSQL sur le même serveur ou hébergé (adapter hôte, port, utilisateur, base)
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/finance_pilot"

# NextAuth — secret dédié production (openssl rand -base64 32), distinct du local
NEXTAUTH_SECRET=""
# Doit matcher l’URL HTTPS servie au public (sans slash final)
NEXTAUTH_URL=""

# Google OAuth — identifiants « Application Web » ; redirection :
#   {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
