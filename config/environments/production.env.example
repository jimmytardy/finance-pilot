# Modèle production (serveur + nginx + PM2) — copier à la racine du dépôt sur la VM :
#   cp config/environments/production.env.example .env.production
#
# Next.js charge `.env.production` avec `pnpm start` / `next start`.
# `ecosystem.config.cjs` charge ce fichier avant de démarrer l’app.

NODE_ENV=production
PORT=3100
HOSTNAME=127.0.0.1

# NEXT_PUBLIC_APP_URL=https://finance-pilot.jimmy-tardy-informatique.fr
