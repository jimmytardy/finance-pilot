# =============================================================================
# Finance Pilot — variables d’environnement (exemple sans secrets ni URLs réelles)
# =============================================================================
# Local : copier vers `.env` ou `.env.local` puis renseigner les valeurs.
# Production (VM, nginx, PM2) : modèle détaillé dans
#   `config/environments/production.env.example`
#   puis par ex. : cp config/environments/production.env.example .env.production
#
# Next.js : `.env.local` > `.env` ; en prod `next start` charge `.env.production`.
# PM2 : `ecosystem.config.cjs` charge `.env.production` puis `.env` à la racine.
# Prisma CLI : lit surtout `.env` (pas `.env.local`) — pour `pnpm prisma db push` :
#   export DATABASE_URL="postgresql://..." && pnpm prisma db push
# =============================================================================

# --- Runtime Node / Next (surtout utile en production derrière reverse proxy) ---
# Laisser vides en local pour les défauts (voir `lib/env.ts` et `ecosystem.config.cjs`).
# NODE_ENV=development
# PORT=
# HOSTNAME=

# URL publique canonique du site, sans slash final (SEO, métadonnées, etc.)
NEXT_PUBLIC_APP_URL=""

# Matomo — laisser vides pour désactiver le suivi (les deux sont requis s’il est actif)
NEXT_PUBLIC_MATOMO_URL=""
NEXT_PUBLIC_MATOMO_SITE_ID=""

# --- Base de données PostgreSQL (Prisma + adaptateur NextAuth) ---
# Local (hors Docker) :
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/finance_pilot"
# Docker sur VPS avec PostgreSQL centralisé (réseau postgres_network, host `postgres`, user typique `admin`) :
# — soit une URL complète (prioritaire pour `docker compose`) :
# DATABASE_URL="postgresql://admin:MOT_DE_PASSE@postgres:5432/finance_pilot?schema=public"
# — soit laisser DATABASE_URL vide et définir POSTGRES_PASSWORD (et optionnellement POSTGRES_USER, POSTGRES_DB) pour docker-compose.yml.

# Créer les tables (User, Account, Session, SimulatorState, etc.) :
#   pnpm prisma db push

# --- NextAuth v4 ---
# Secret de signature des cookies (ex. : openssl rand -base64 32)
NEXTAUTH_SECRET=""
# URL publique de l’app, sans slash final — doit correspondre à l’URL réelle du navigateur
NEXTAUTH_URL="http://localhost:3000"

# OAuth Google — type « Application Web » ; URI de redirection autorisée :
#   {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Même identifiant client que ci-dessus (affiche le bouton « Connexion Google » côté client)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
