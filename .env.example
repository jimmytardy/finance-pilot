# Base PostgreSQL (ex. Neon, Supabase, ou Postgres local)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/finance_pilot"
#
# Créer les tables (User, Account, Session, SimulatorState, etc.) une fois DATABASE_URL valide dans .env :
#   pnpm prisma db push
# La CLI Prisma charge surtout le fichier .env (pas .env.local). Pour une commande ponctuelle :
#   export DATABASE_URL="postgresql://..." && pnpm prisma db push

# NextAuth v4 — secret (ex. openssl rand -base64 32)
NEXTAUTH_SECRET=""

# URL publique de l’app (sans slash final), ex. https://finance.example.com
NEXTAUTH_URL="http://localhost:3000"

# OAuth Google — Console Cloud : type « Application Web », URI de redirection :
#   {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Même identifiant client côté navigateur (affiche le bouton « Connexion Google »)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
