# =============================================================================
# Finance Pilot — variables d’environnement (exemple)
# =============================================================================
# Ne commitez jamais un fichier `.env`, `.env.development` ou `.env.production`
# contenant des valeurs réelles : copiez les modèles depuis `config/environments/`.
#
# Développement (next dev) — Next charge automatiquement `.env.development` :
#   cp config/environments/development.env.example .env.development
#
# Production (next start / PM2) — Next charge `.env.production` ; PM2 charge aussi
#   ces fichiers depuis `ecosystem.config.cjs` :
#   cp config/environments/production.env.example .env.production
#
# Fichier optionnel à la racine (surcharges locales, non versionné) : `.env`
#
# -----------------------------------------------------------------------------

# Environnement Node : development | production | test
NODE_ENV=production

# Port d’écoute de Next.js (ex. 3100 derrière nginx pour éviter le conflit avec un autre service sur 3000)
PORT=3100

# Interface réseau : 127.0.0.1 recommandé derrière un reverse proxy sur la même machine
HOSTNAME=127.0.0.1

# URL publique de l’app (optionnel — utile pour liens absolus / métadonnées futures)
# NEXT_PUBLIC_APP_URL=https://finance-pilot.jimmy-tardy-informatique.fr

# Matomo — suivi d’audience (optionnel ; les deux variables requises pour activer le script)
# NEXT_PUBLIC_MATOMO_URL=https://analytics.jimmy-tardy-informatique.fr
# NEXT_PUBLIC_MATOMO_SITE_ID=1
